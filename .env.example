# netascan environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# NVD (National Vulnerability Database) API key
# Get one free at: https://nvd.nist.gov/developers/request-an-api-key
# Without it: 5 req/30s limit. With it: 50 req/30s
NVD_API_KEY=

# MacVendors API key (optional)
# Get one at: https://macvendors.com/api
# Without it: 1 req/sec on free tier. With key: higher limits
MAC_VENDORS_API_KEY=

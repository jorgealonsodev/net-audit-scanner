# netascan environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# NVD (National Vulnerability Database) API key
# Get one free at: https://nvd.nist.gov/developers/request-an-api-key
# Without it: 5 req/30s limit. With it: 50 req/30s
NVD_API_KEY=

# MacVendors API key (optional — only needed for paid plan higher limits)
# No key required for up to 1,000 req/day at 1 req/sec (free, no registration)
# Get a paid plan key at: https://macvendors.com/api
MAC_VENDORS_API_KEY=
